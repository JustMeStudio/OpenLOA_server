#公钥
SECRET_KEY = openloa-openloa-openloa-openloa-openloa-openloa-openloa-openloa

#数据库地址
DB_PATH = database/main.db

#初始管理员账户（首次初始化数据库时自动创建）
ADMIN_EMAIL = openloa@openloa.com
ADMIN_PASSWORD = openloa123

#ChromaDB 本地路径
CHROMADB_PATH_CS = database/chromadb_cs

#Redis缓存配置（支持多worker部署）
REDIS_URL = redis://localhost:6379
# 如果Redis设置了密码，使用：REDIS_URL = redis://:password@localhost:6379
# 如果使用远程Redis，使用：REDIS_URL = redis://user:password@redis-host:port

#Token有效期设置
REFRESH_TOKEN_EXPIRE_DAYS = 14
ACCESS_TOKEN_EXPIRE_HOURS = 2

#SMTP邮件服务器配置（用于发送注册验证邮件、密码重置邮件等）
ALIYUN_SMTP_PASSWORD = <your-smtp-password-here>

#阿里云
ALIYUN_ACCESS_KEY_ID = <your-access-key-id-here>
ALIYUN_ACCESS_KEY_SECRET = <your-access-key-secret-here>

#阿里云OSS
ALIYUN_OSS_ENDPOINT = <your-oss-endpoint-here>  # 例如：oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME = <your-oss-bucket-name-here>

#用户上传文件
UPLOAD_MAX_FILE_SIZE = 50  # 50MB

# CDN设置
CDN_ENABLED = False  # 是否启用CDN
CDN_DOMAIN = <your-cdn-domain-here>  # CDN域名，例如：cdn.example.com
CDN_PROTOCOL = https  # https 或 http